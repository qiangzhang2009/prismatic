// Prismatic — Prisma Database Schema
// User Management System with Email, Phone, and WeChat OAuth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Identity
  email         String?   @unique
  emailVerified DateTime?

  phone         String?   @unique
  phoneVerified DateTime?

  // Password (for email/phone login)
  passwordHash  String?

  // WeChat OAuth
  wechatOpenid  String?   @unique
  wechatUnionid String?   @unique
  wechatNickname String?
  wechatAvatar  String?

  // GitHub OAuth
  githubId      String?   @unique
  githubUsername String?
  githubAvatar  String?

  // Google OAuth
  googleId      String?   @unique
  googleEmail   String?   @unique
  googleAvatar  String?

  // Account binding
  // A user can have multiple OAuth accounts linked to the same profile
  accounts      Account[]

  // Display
  name          String?
  avatar        String?

  // Preferences
  preferences   Json      @default("{}")

  // Usage
  conversations Conversation[]
  messages      Message[]
  comments      Comment[]

  // Auth events
  authEvents    AuthEvent[]

  // Status
  status        UserStatus @default(ACTIVE)
  bannedAt      DateTime?
  banReason     String?

  // Token bucket for rate limiting
  tokenCount    Int        @default(0)
  tokenUpdatedAt DateTime  @default(now())

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

// ─── OAuth Account ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          AuthProvider
  providerAccountId String

  // OAuth fields
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?

  // Provider-specific
  idToken           String?
  sessionState      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum AuthProvider {
  EMAIL    // Email + password
  PHONE    // Phone + password
  WECHAT   // WeChat OAuth
  GITHUB   // GitHub OAuth
  GOOGLE   // Google OAuth
}

// ─── Verification Token ────────────────────────────────────────────────────────

model VerificationToken {
  id        String   @id @default(cuid())
  identifier String
  token     String   @unique
  type      VerificationType
  expiresAt DateTime

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum VerificationType {
  VERIFY_EMAIL      // Verify email ownership
  VERIFY_PHONE      // Verify phone ownership
  RESET_PASSWORD    // Password reset
  BIND_WECHAT       // Bind WeChat account
  BIND_GITHUB       // Bind GitHub account
  BIND_GOOGLE       // Bind Google account
}

// ─── SMS / Email Verification Code ────────────────────────────────────────────

model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // email or phone number
  code       String
  type       VerificationCodeType
  expiresAt  DateTime
  attempts   Int      @default(0)
  maxAttempts Int    @default(5)

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@index([identifier, type, expiresAt])
  @@map("verification_codes")
}

enum VerificationCodeType {
  REGISTER_EMAIL    // Email registration code
  LOGIN_EMAIL       // Email login code
  REGISTER_PHONE    // Phone registration code
  LOGIN_PHONE       // Phone login code (magic link / OTP)
  RESET_PASSWORD_EMAIL
  RESET_PASSWORD_PHONE
  BIND_PHONE
  BIND_WECHAT
}

// ─── Auth Event Log ─────────────────────────────────────────────────────────────

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  eventType AuthEventType
  provider  AuthProvider?
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?  // failure reason if any

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_events")
}

enum AuthEventType {
  // Registration
  REGISTER_EMAIL
  REGISTER_PHONE
  REGISTER_PASSWORD

  // Login
  LOGIN_EMAIL
  LOGIN_PHONE
  LOGIN_PASSWORD
  LOGIN_WECHAT
  LOGIN_GITHUB
  LOGIN_GOOGLE

  // Account actions
  CHANGE_PASSWORD
  RESET_PASSWORD
  BIND_WECHAT
  BIND_GITHUB
  BIND_GOOGLE
  UNBIND_ACCOUNT
  DELETE_ACCOUNT

  // Admin
  ADMIN_BAN
  ADMIN_UNBAN
  ADMIN_SUSPEND

  // Security
  RATE_LIMITED
  SUSPICIOUS_ACTIVITY
}

// ─── Conversation ──────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String?
  mode       String   // solo, prism, roundtable, mission
  participants String[] // persona IDs

  messages   Message[]

  archived   Boolean  @default(false)
  tags       String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, archived])
  @@map("conversations")
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           String   // user, assistant, system
  content        String

  // For agent messages
  personaId     String?
  modelUsed      String?
  tokensUsed     Int?
  latencyMs      Int?
  confidence     Float?

  // Multi-agent metadata
  round          Int?
  consensus      Boolean? @default(false)

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("messages")
}

// ─── Comment ─────────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String?  // null = anonymous
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Anonymous user fields
  nickname    String?
  gender      String?  // male | female | null
  avatarSeed  String?  // random seed for DiceBear avatar
  ipHash      String?

  // Geo (filled by server-side IP lookup)
  geoCountryCode String?
  geoCountry     String?  // formatted, e.g. "中国香港"
  geoRegion      String?
  geoCity        String?

  // Threading
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  // Type: root comment or reply
  type       String   @default("comment")  // comment | reply

  // Reactions stored as JSON { emoji: count }
  reactions  Json     @default("{}")

  // Status
  status     String   @default("published")  // published | deleted | flagged

  // Persona context (which persona page this was left on)
  personaSlug String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([parentId])
  @@index([status, createdAt])
  @@index([personaSlug, createdAt])
  @@map("comments")
}

// ─── Guardian Duty ─────────────────────────────────────────────────────────────

model GuardianDuty {
  id               String   @id @default(cuid())
  personaId        String
  dutyDate         DateTime @db.Date
  interactionCount Int      @default(0)
  interactionIds   String[] @default([])
  status           String   @default("pending")  // pending | completed | overdue
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([personaId, dutyDate])
  @@index([dutyDate, status])
  @@map("guardian_duties")
}
