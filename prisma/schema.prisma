// Prismatic — Prisma Database Schema
// User Management System with Email, Phone, and WeChat OAuth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Identity
  email         String?   @unique
  emailVerified DateTime?

  phone         String?   @unique
  phoneVerified DateTime?

  // Password (for email/phone login)
  passwordHash  String?

  // WeChat OAuth
  wechatOpenid  String?   @unique
  wechatUnionid String?   @unique
  wechatNickname String?
  wechatAvatar  String?

  // GitHub OAuth
  githubId      String?   @unique
  githubUsername String?
  githubAvatar  String?

  // Google OAuth
  googleId      String?   @unique
  googleEmail   String?   @unique
  googleAvatar  String?

  // Account binding
  // A user can have multiple OAuth accounts linked to the same profile
  accounts      Account[]

  // Display
  name          String?
  avatar        String?

  // Preferences
  preferences   Json      @default("{}")

  // Usage
  conversations Conversation[]
  messages      Message[]
  comments      Comment[]

  // Auth events
  authEvents    AuthEvent[]

  // Status
  status        UserStatus @default(ACTIVE)
  bannedAt      DateTime?
  banReason     String?

  // Role & Subscription (新增字段 - 替代旧 prismatic_users 表)
  role          UserRole?  @default(FREE)  // ADMIN, PRO, FREE
  plan          SubscriptionPlan? @default(FREE)  // FREE, MONTHLY, YEARLY, LIFETIME
  credits       Int        @default(0)  // 充值问答条数

  // Token bucket for rate limiting
  tokenCount    Int        @default(0)
  tokenUpdatedAt DateTime  @default(now())

  // User-provided API Key（加密存储，永远不明文暴露）
  apiKeyEncrypted String?   // AES-256-GCM 加密后的 Key
  apiKeyIv        String?   // 加密向量
  apiKeyHash      String?   // Key 的前 8 位 hash（用于显示脱敏格式 "sk-xxxx...xxxx"）
  apiKeySetAt     DateTime? // 设置时间
  apiKeyProvider  String?   @default("deepseek") // deepseek | openai | anthropic
  apiKeyStatus    String?   // valid | expired | invalid | null

  // Analytics relations
  sessions      UserSession[]
  events        UserEvent[]
  dailyMetrics  DailyMetric[]
  auditLogsAsAdmin    AdminAuditLog[] @relation("AdminAuditAsAdmin")
  auditLogsAsTarget   AdminAuditLog[] @relation("AdminAuditAsTarget")

  // Credit logs
  creditLogs    UserCreditLog[]

  @@map("users")
}

// ─── Enums ───────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PRO
  FREE
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  YEARLY
  LIFETIME
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

// ─── OAuth Account ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          AuthProvider
  providerAccountId String

  // OAuth fields
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?

  // Provider-specific
  idToken           String?
  sessionState      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum AuthProvider {
  EMAIL    // Email + password
  PHONE    // Phone + password
  WECHAT   // WeChat OAuth
  GITHUB   // GitHub OAuth
  GOOGLE   // Google OAuth
}

// ─── Verification Token ────────────────────────────────────────────────────────

model VerificationToken {
  id        String   @id @default(cuid())
  identifier String
  token     String   @unique
  type      VerificationType
  expiresAt DateTime

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum VerificationType {
  VERIFY_EMAIL      // Verify email ownership
  VERIFY_PHONE      // Verify phone ownership
  RESET_PASSWORD    // Password reset
  BIND_WECHAT       // Bind WeChat account
  BIND_GITHUB       // Bind GitHub account
  BIND_GOOGLE       // Bind Google account
}

// ─── SMS / Email Verification Code ────────────────────────────────────────────

model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // email or phone number
  code       String
  type       VerificationCodeType
  expiresAt  DateTime
  attempts   Int      @default(0)
  maxAttempts Int    @default(5)

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@unique([identifier, type])
  @@index([identifier, type, expiresAt])
  @@map("verification_codes")
}

enum VerificationCodeType {
  REGISTER_EMAIL    // Email registration code
  LOGIN_EMAIL       // Email login code
  REGISTER_PHONE    // Phone registration code
  LOGIN_PHONE       // Phone login code (magic link / OTP)
  RESET_PASSWORD_EMAIL
  RESET_PASSWORD_PHONE
  BIND_PHONE
  BIND_WECHAT
}

// ─── Auth Event Log ─────────────────────────────────────────────────────────────

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  eventType AuthEventType
  provider  AuthProvider?
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?  // failure reason if any

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_events")
}

enum AuthEventType {
  // Registration
  REGISTER_EMAIL
  REGISTER_PHONE
  REGISTER_PASSWORD

  // Login
  LOGIN_EMAIL
  LOGIN_PHONE
  LOGIN_PASSWORD
  LOGIN_WECHAT
  LOGIN_GITHUB
  LOGIN_GOOGLE

  // Account actions
  CHANGE_PASSWORD
  RESET_PASSWORD
  BIND_WECHAT
  BIND_GITHUB
  BIND_GOOGLE
  UNBIND_ACCOUNT
  DELETE_ACCOUNT

  // Admin
  ADMIN_BAN
  ADMIN_UNBAN
  ADMIN_SUSPEND

  // Security
  RATE_LIMITED
  SUSPICIOUS_ACTIVITY
}

// ─── Conversation ──────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String?
  mode       String   // solo, prism, roundtable, mission
  participants String[] // persona IDs

  messages   Message[]

  archived   Boolean  @default(false)
  tags       String[]

  // Analytics: pre-computed stats (avoid real-time COUNT)
  messageCount Int     @default(0)
  totalTokens  Int     @default(0)
  totalCost    Decimal? @default(0)
  personaIds   String[] @default([])  // explicit persona IDs array

  // Relations for analytics
  userEvents   UserEvent[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, archived])
  @@map("conversations")
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           String   // user | assistant | system
  content        String

  // For agent messages
  personaId     String?
  modelUsed      String?
  tokensUsed     Int?
  latencyMs      Int?
  confidence     Float?

  // Multi-agent metadata
  round          Int?
  consensus      Boolean? @default(false)

  // Analytics: token usage and cost tracking
  tokensInput    Int?     @default(0)
  tokensOutput   Int?     @default(0)
  apiCost        Decimal? @default(0)
  metadata       Json?    @default("{}")  // {temperature, top_p, model_params...}

  // Data source tracking
  source          String?   @default("web")  // web | api | cron
  parentMessageId String?   // multi-turn conversation parent

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, createdAt, source])
  @@index([personaId, createdAt])
  @@map("messages")
}

// ─── Comment ─────────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String?  // null = anonymous
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Anonymous user fields
  nickname    String?
  gender      String?  // male | female | null
  avatarSeed  String?  // random seed for DiceBear avatar
  ipHash      String?

  // Geo (filled by server-side IP lookup)
  geoCountryCode String?
  geoCountry     String?  // formatted, e.g. "中国香港"
  geoRegion      String?
  geoCity        String?

  // Threading
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  // Type: root comment or reply
  type       String   @default("comment")  // comment | reply

  // Reactions stored as JSON { emoji: count }
  reactions  Json     @default("[]")

  // Status
  status     String   @default("published")  // published | deleted | flagged

  // Persona context (which persona page this was left on)
  personaSlug String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([parentId])
  @@index([status, createdAt])
  @@index([personaSlug, createdAt])
  @@map("comments")
}

// ─── Guardian Discussions (autonomous topic-based discussions) ──────────────────────

model GuardianDiscussion {
  id           String   @id @default(cuid())
  topic        String
  topicSource  String   @default("auto")  // auto | manual | guardian
  content      String   @default("")      // full discussion content (HTML/markdown)
  participantIds String[] @default([])
  roundCount   Int      @default(0)
  viewCount    Int      @default(0)
  status       String   @default("active") // active | completed | archived
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@index([startedAt])
  @@map("guardian_discussions")
}

// ─── Guardian Duty ─────────────────────────────────────────────────────────────

model GuardianDuty {
  id               String   @id @default(cuid())
  personaId        String
  dutyDate         DateTime @db.Date
  interactionCount Int      @default(0)
  interactionIds   String[] @default([])
  status           String   @default("pending")  // pending | completed | overdue
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([personaId, dutyDate])
  @@index([dutyDate, status])
  @@map("guardian_duties")
}

// ─── Analytics: User Session ────────────────────────────────────────────────────

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId        String   @unique
  ipAddress        String?
  userAgent        String?
  referrer         String?
  country          String?
  deviceType       String?  // mobile | desktop | tablet
  browser          String?
  os               String?

  startedAt        DateTime @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  pageViews        Int      @default(0)
  messagesSent     Int      @default(0)

  @@index([userId, startedAt])
  @@index([sessionId])
  @@map("user_sessions")
}

// ─── Analytics: User Events ─────────────────────────────────────────────────────

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId  String?
  eventType  String   // page_view | button_click | persona_chat_start | feature_used | admin_action
  eventName  String
  properties Json?    @default("{}")
  context    Json?    @default("{}")

  personaId  String?
  personaName String?
  persona    Persona? @relation(fields: [personaId], references: [slug])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId])
  @@map("user_events")
}

// ─── Analytics: Daily Metrics ────────────────────────────────────────────────────

model DailyMetric {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  statDate  DateTime @db.Date
  messagesSent        Int      @default(0)
  personasUsedCount   Int      @default(0)
  timeSpentSeconds    Int      @default(0)
  featuresUsed        Json?    @default("{}")
  lastConversationAt  DateTime?

  @@unique([userId, statDate])
  @@index([userId, statDate])
  @@index([statDate])
  @@map("daily_metrics")
}

// ─── Analytics: Admin Audit Log ─────────────────────────────────────────────────

model AdminAuditLog {
  id            String   @id @default(cuid())
  adminId       String
  admin         User     @relation("AdminAuditAsAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  targetUserId  String
  targetUser    User     @relation("AdminAuditAsTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  action        String   // user_role_change | user_plan_change | user_credits_add | user_delete
  oldValues     Json?    @default("{}")
  newValues     Json?    @default("{}")
  reason        String?

  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── Analytics: System Daily Stats ───────────────────────────────────────────────

model SystemDailyStat {
  id              String   @id @default(cuid())
  statDate        DateTime @unique @db.Date

  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  totalMessages   Int      @default(0)
  totalConversations Int   @default(0)
  totalApiCost    Decimal? @default(0)
  revenueEstimate Decimal? @default(0)

  dau             Int      @default(0)
  mau             Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("system_daily_stats")
}

// ─── Persona (for analytics reference) ──────────────────────────────────────────
// Note: Personas are defined in src/lib/personas.ts as constants.
// This model stores persona metadata that needs DB queries (views, conversations).
// The full persona definitions remain in code (version-controlled).

model Persona {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  description String?
  domain      String   // e.g. "product", "strategy"
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Analytics relations (optional)
  events        UserEvent[]

  @@index([slug])
  @@index([domain])
  @@map("personas")
}

// ─── Billing: User Credit Log ──────────────────────────────────────────────────

model UserCreditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String   // RECHARGE | CONSUME | EXPIRE | ADMIN_ADD | ADMIN_DEDUCT | REFUND

  amount          Int       // 正数=增加，负数=减少
  balance         Int       // 变动后即时余额

  conversationId  String?
  messageId       String?

  description     String?

  operatorId      String?
  ipAddress       String?

  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([createdAt])
  @@map("user_credit_logs")
}
