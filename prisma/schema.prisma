// Prismatic — Prisma Database Schema
// User Management System with Email, Phone, and WeChat OAuth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Identity
  email         String?   @unique
  emailVerified DateTime?

  phone         String?   @unique
  phoneVerified DateTime?

  // Password (for email/phone login)
  passwordHash  String?

  // WeChat OAuth
  wechatOpenid  String?   @unique
  wechatUnionid String?   @unique
  wechatNickname String?
  wechatAvatar  String?

  // GitHub OAuth
  githubId      String?   @unique
  githubUsername String?
  githubAvatar  String?

  // Google OAuth
  googleId      String?   @unique
  googleEmail   String?   @unique
  googleAvatar  String?

  // Account binding
  // A user can have multiple OAuth accounts linked to the same profile
  accounts      Account[]

  // Display
  name          String?
  avatar        String?

  // Preferences
  preferences   Json      @default("{}")

  // Usage
  conversations Conversation[]
  messages      Message[]
  comments      Comment[]

  // Auth events
  authEvents    AuthEvent[]

  // Status
  status        UserStatus @default(ACTIVE)
  bannedAt      DateTime?
  banReason     String?

  // Role & Subscription
  role          UserRole?  @default(FREE)  // ADMIN, PRO, FREE
  plan          SubscriptionPlan? @default(FREE)  // FREE, MONTHLY, YEARLY, LIFETIME

  // ─── Simplified Points System (Pure Credit Model) ────────────────────────────
  // 统一积分系统：所有 AI 互动消耗积分，打通全站
  //
  // 积分来源：
  // 1. 每日积分 (dailyCredits)：每天凌晨 0 点自动获得 20 积分，不积累
  // 2. 充值积分 (credits)：永久有效，用于超额消费
  //
  // 消耗规则：
  // - 优先消耗每日积分，用完则消耗充值积分
  // - 充值积分用完后才弹窗提醒购买
  //
  // 字段说明：
  // - credits: 充值积分余额（永久有效）
  // - dailyCredits: 当日积分余额（每日重置）
  // - lastDailyResetAt: 上次每日重置时间（用于判断是否需要刷新）
  credits       Int        @default(0)  // 充值积分（永久有效）
  dailyCredits  Int        @default(20) // 当日积分（每日凌晨重置）
  lastDailyResetAt DateTime @default(now()) // 上次每日重置时间

  // Token bucket for rate limiting
  tokenCount    Int        @default(0)
  tokenUpdatedAt DateTime  @default(now())

  // User-provided API Key（加密存储，永远不明文暴露）
  apiKeyEncrypted String?   // AES-256-GCM 加密后的 Key
  apiKeyIv        String?   // 加密向量
  apiKeyHash      String?   // Key 的前 8 位 hash（用于显示脱敏格式 "sk-xxxx...xxxx"）
  apiKeySetAt     DateTime? // 设置时间
  apiKeyProvider  String?   @default("deepseek") // deepseek | openai | anthropic
  apiKeyStatus    String?   // valid | expired | invalid | null

  // Analytics relations
  sessions      UserSession[]
  events        UserEvent[]
  dailyMetrics  DailyMetric[]
  auditLogsAsAdmin    AdminAuditLog[] @relation("AdminAuditAsAdmin")
  auditLogsAsTarget   AdminAuditLog[] @relation("AdminAuditAsTarget")

  // Credit logs
  creditLogs    UserCreditLog[]

  // Multi-device sync
  devices        Device[]
  syncLogs       SyncLog[]
  syncConflicts  SyncConflict[]
  conversationMigrations ConversationMigration[]

  @@map("users")
}

// ─── Enums ───────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PRO
  FREE
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  YEARLY
  LIFETIME
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

// ─── OAuth Account ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          AuthProvider
  providerAccountId String

  // OAuth fields
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?

  // Provider-specific
  idToken           String?
  sessionState      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum AuthProvider {
  EMAIL    // Email + password
  PHONE    // Phone + password
  WECHAT   // WeChat OAuth
  GITHUB   // GitHub OAuth
  GOOGLE   // Google OAuth
}

// ─── Verification Token ────────────────────────────────────────────────────────

model VerificationToken {
  id        String   @id @default(cuid())
  identifier String
  token     String   @unique
  type      VerificationType
  expiresAt DateTime

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum VerificationType {
  VERIFY_EMAIL      // Verify email ownership
  VERIFY_PHONE      // Verify phone ownership
  RESET_PASSWORD    // Password reset
  BIND_WECHAT       // Bind WeChat account
  BIND_GITHUB       // Bind GitHub account
  BIND_GOOGLE       // Bind Google account
}

// ─── SMS / Email Verification Code ────────────────────────────────────────────

model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // email or phone number
  code       String
  type       VerificationCodeType
  expiresAt  DateTime
  attempts   Int      @default(0)
  maxAttempts Int    @default(5)

  createdAt DateTime @default(now())
  usedAt   DateTime?

  @@unique([identifier, type])
  @@index([identifier, type, expiresAt])
  @@map("verification_codes")
}

enum VerificationCodeType {
  REGISTER_EMAIL    // Email registration code
  LOGIN_EMAIL       // Email login code
  REGISTER_PHONE    // Phone registration code
  LOGIN_PHONE       // Phone login code (magic link / OTP)
  RESET_PASSWORD_EMAIL
  RESET_PASSWORD_PHONE
  BIND_PHONE
  BIND_WECHAT
}

// ─── Auth Event Log ─────────────────────────────────────────────────────────────

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  eventType AuthEventType
  provider  AuthProvider?
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?  // failure reason if any

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_events")
}

enum AuthEventType {
  // Registration
  REGISTER_EMAIL
  REGISTER_PHONE
  REGISTER_PASSWORD

  // Login
  LOGIN_EMAIL
  LOGIN_PHONE
  LOGIN_PASSWORD
  LOGIN_WECHAT
  LOGIN_GITHUB
  LOGIN_GOOGLE

  // Account actions
  CHANGE_PASSWORD
  RESET_PASSWORD
  BIND_WECHAT
  BIND_GITHUB
  BIND_GOOGLE
  UNBIND_ACCOUNT
  DELETE_ACCOUNT

  // Admin
  ADMIN_BAN
  ADMIN_UNBAN
  ADMIN_SUSPEND

  // Security
  RATE_LIMITED
  SUSPICIOUS_ACTIVITY
}

// ─── Conversation ──────────────────────────────────────────────────────────────

enum ConversationType {
  CHAT       // standard single or multi-persona chat
  MISSION    // goal-oriented multi-turn task completion
  DEBATE     // structured adversarial dialogue
  GUARDIAN   // autonomous guardian system discussions
  TCM        // AI 中医助手对话
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title      String?
  type       ConversationType @default(CHAT)
  mode       String   @default("solo")
  participants String[]
  personaIds String[] @default([])

  messages   Message[]

  archived   Boolean  @default(false)
  tags       String[] @default([])

  // Analytics: pre-computed stats (updated atomically in transactions)
  messageCount Int     @default(0)
  totalTokens  Int     @default(0)
  totalCost    Decimal? @default(0)

  // Sync: which devices have synced this conversation
  deviceIds   String[] @default([])
  lastSyncedAt DateTime?

  // Relations for analytics
  userEvents   UserEvent[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, archived, updatedAt])
  @@index([userId, type, updatedAt])
  @@index([type, updatedAt])
  @@map("conversations")
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role           String   // user | assistant | system
  content        String

  // For agent messages
  personaId     String?
  modelUsed      String?
  tokensUsed     Int?
  latencyMs      Int?
  confidence     Float?

  // Multi-agent metadata
  round          Int?
  consensus      Boolean? @default(false)

  // Analytics: token usage and cost tracking
  tokensInput    Int?     @default(0)
  tokensOutput   Int?     @default(0)
  apiCost        Decimal? @default(0)
  metadata       Json?    @default("{}")  // {temperature, top_p, model_params...}

  // Data source tracking
  source          String?   @default("web")  // web | api | cron
  parentMessageId String?   // multi-turn conversation parent

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, createdAt, source])
  @@index([personaId, createdAt])
  @@map("messages")
}

// ─── Comment ─────────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String?  // null = anonymous
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Anonymous user fields
  nickname    String?
  gender      String?  // male | female | null
  avatarSeed  String?  // random seed for DiceBear avatar
  ipHash      String?

  // Geo (filled by server-side IP lookup)
  geoCountryCode String?
  geoCountry     String?  // formatted, e.g. "中国香港"
  geoRegion      String?
  geoCity        String?

  // Threading
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  // Type: root comment or reply
  type       String   @default("comment")  // comment | reply

  // Reactions stored as JSON { emoji: count }
  reactions  Json     @default("[]")

  // Status
  status     String   @default("published")  // published | deleted | flagged

  // Persona context (which persona page this was left on)
  personaSlug String?

  // ── Guardian mention ──────────────────────────────────────────────────────
  // The guardian @-mentioned in this comment (if any)
  mentionedGuardianId    String?
  // Guardian's reply content (filled asynchronously)
  mentionedGuardianReply String?
  // When the guardian replied
  mentionedGuardianRepliedAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([mentionedGuardianId])
  @@index([userId, createdAt])
  @@index([parentId])
  @@index([status, createdAt])
  @@index([personaSlug, createdAt])
  @@map("comments")
}

// ─── Guardian Discussions (autonomous topic-based discussions) ──────────────────────

model GuardianDiscussion {
  id           String   @id @default(cuid())
  topic        String
  topicSource  String   @default("auto")  // auto | manual | guardian
  content      String   @default("")      // full discussion content (HTML/markdown)
  participantIds String[] @default([])
  roundCount   Int      @default(0)
  viewCount    Int      @default(0)
  status       String   @default("active") // active | completed | archived
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@index([startedAt])
  @@map("guardian_discussions")
}

// ─── Guardian Duty ─────────────────────────────────────────────────────────────

model GuardianDuty {
  id               String   @id @default(cuid())
  personaId        String
  dutyDate         DateTime @db.Date
  interactionCount Int      @default(0)
  interactionIds   String[] @default([])
  status           String   @default("pending")  // pending | completed | overdue
  completedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([personaId, dutyDate])
  @@index([dutyDate, status])
  @@map("guardian_duties")
}

// ─── Analytics: User Session ────────────────────────────────────────────────────

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId        String   @unique
  ipAddress        String?
  userAgent        String?
  referrer         String?
  country          String?
  deviceType       String?  // mobile | desktop | tablet
  browser          String?
  os               String?

  startedAt        DateTime @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  pageViews        Int      @default(0)
  messagesSent     Int      @default(0)

  @@index([userId, startedAt])
  @@index([sessionId])
  @@map("user_sessions")
}

// ─── Analytics: User Events ─────────────────────────────────────────────────────

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId  String?
  eventType  String   // page_view | button_click | persona_chat_start | feature_used | admin_action
  eventName  String
  properties Json?    @default("{}")
  context    Json?    @default("{}")

  personaId  String?
  personaName String?
  persona    Persona? @relation(fields: [personaId], references: [slug])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId])
  @@map("user_events")
}

// ─── Analytics: Daily Metrics ────────────────────────────────────────────────────

model DailyMetric {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  statDate  DateTime @db.Date
  messagesSent        Int      @default(0)
  personasUsedCount   Int      @default(0)
  timeSpentSeconds    Int      @default(0)
  featuresUsed        Json?    @default("{}")
  lastConversationAt  DateTime?

  @@unique([userId, statDate])
  @@index([userId, statDate])
  @@index([statDate])
  @@map("daily_metrics")
}

// ─── Analytics: Admin Audit Log ─────────────────────────────────────────────────

model AdminAuditLog {
  id            String   @id @default(cuid())
  adminId       String
  admin         User     @relation("AdminAuditAsAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  targetUserId  String
  targetUser    User     @relation("AdminAuditAsTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  action        String   // user_role_change | user_plan_change | user_credits_add | user_delete
  oldValues     Json?    @default("{}")
  newValues     Json?    @default("{}")
  reason        String?

  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── Analytics: System Daily Stats ───────────────────────────────────────────────

model SystemDailyStat {
  id              String   @id @default(cuid())
  statDate        DateTime @unique @db.Date

  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  totalMessages   Int      @default(0)
  totalConversations Int   @default(0)
  totalApiCost    Decimal? @default(0)
  revenueEstimate Decimal? @default(0)

  dau             Int      @default(0)
  mau             Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("system_daily_stats")
}

// ─── Persona (for analytics reference) ──────────────────────────────────────────
// Note: Personas are defined in src/lib/personas.ts as constants.
// This model stores persona metadata that needs DB queries (views, conversations).
// The full persona definitions remain in code (version-controlled).

model Persona {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameZh      String
  description String?
  domain      String   // e.g. "product", "strategy"
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Analytics relations (optional)
  events        UserEvent[]

  @@index([slug])
  @@index([domain])
  @@map("personas")
}

// ─── Billing: User Credit Log ──────────────────────────────────────────────────

model UserCreditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String   // RECHARGE | CONSUME | EXPIRE | ADMIN_ADD | ADMIN_DEDUCT | REFUND
                          // DAILY_GRANT | DAILY_RESET（新增每日积分相关类型）

  amount          Int       // 正数=增加，负数=减少
  balance         Int       // 变动后即时余额

  conversationId  String?
  messageId       String?

  description     String?

  operatorId      String?
  ipAddress       String?

  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([createdAt])
  @@map("user_credit_logs")
}

// ─── News (legacy) ────────────────────────────────────────────────────────────

model NewsSnapshot {
  id            String   @id @default(cuid())
  sourceId      String
  sourceName    String
  snapshotAt    DateTime @default(now())
  snapshotDate  DateTime @db.Date
  itemCount    Int      @default(0)
  status       String   @default("success") // success | error | partial
  errorMsg     String?

  @@unique([sourceId, snapshotDate])
  @@map("news_snapshots")
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  url       String?
  source    String?
  createdAt DateTime @default(now())

  @@map("news_items")
}

// ─── Distillation Session ─────────────────────────────────────────────────────

model DistillSession {
  id              String   @id @default(cuid())

  // Core info
  personaName     String
  personaId       String   // can be empty for new personas
  personaDomain   String   @default("philosophy")

  // Status
  status          String   @default("pending") // pending | running | completed | failed | cancelled

  // Options snapshot
  options         Json?    @default("{}")

  // Result (populated when completed)
  result          Json?    // FullDistillationResult serialized

  // Error
  error           String?

  // Metadata
  totalCost       Float    @default(0)
  totalTokens     Int      @default(0)

  // Relations
  corpus          DistillCorpusItem[]
  savedPersona    DistilledPersona?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([status])
  @@index([personaId])
  @@index([personaName])
  @@index([createdAt])
  @@map("distill_sessions")
}

// ─── Distillation Corpus (persistent raw collected data) ─────────────────────────

model DistillCorpusItem {
  id              String   @id @default(cuid())
  sessionId       String
  session         DistillSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Source identification
  collectorType    String   // twitter | blog | weibo | video | podcast | book | forum
  source          String   // URL or identifier
  sourceName      String?  // Display name (account handle, blog title, etc.)

  // Content
  content         String   // Full text content
  author          String?
  publishedAt     DateTime?
  url             String?

  // Metadata
  wordCount       Int      @default(0)
  language        String   @default("mixed") // zh | en | mixed
  quality         Float?   // Quality score from collector

  // Raw metadata snapshot
  rawMetadata     Json?    @default("{}")

  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([collectorType])
  @@index([language])
  @@map("distill_corpus_items")
}

// ─── Distilled Persona (saved to DB for website library) ──────────────────────

model DistilledPersona {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         DistillSession @relation(fields: [sessionId], references: [id])

  // Identity (mirrors Persona type fields)
  slug            String   @unique
  name            String
  nameZh          String   @default("")
  nameEn          String   @default("")
  domain          String   @default("philosophy") // comma-separated or JSON

  // Basic info
  tagline         String   @default("")
  taglineZh       String   @default("")
  avatar          String?
  accentColor     String   @default("#6366f1")
  gradientFrom    String   @default("#6366f1")
  gradientTo      String   @default("#8b5cf6")
  brief           String   @default("")
  briefZh         String   @default("")

  // Core distillation output
  mentalModels    Json     @default("[]")    // MentalModel[]
  decisionHeuristics Json @default("[]")      // string[]
  expressionDNA   Json     // ExpressionDNA object
  values          Json     @default("[]")    // Value[]
  antiPatterns    Json     @default("[]")    // string[]

  // Boundaries & qualities
  tensions        Json     @default("[]")    // Tension[]
  honestBoundaries Json    @default("[]")    // HonestBoundary[]
  strengths       Json     @default("[]")    // string[]
  blindspots      Json     @default("[]")    // string[]

  // System prompts
  systemPromptTemplate String @default("")
  identityPrompt     String @default("")

  // Extended
  reasoningStyle   String?
  decisionFramework Json?
  keyQuotes        Json?
  lifePhilosophy   Json?

  // Quality metrics from distillation
  finalScore      Float   @default(0)
  qualityGrade    String  @default("F")
  thresholdPassed Boolean @default(false)
  qualityGateSkipped Boolean @default(false)

  // Score breakdown (4 dimensions, computed at distillation time)
  // voiceFidelity: 表达DNA还原度 (权重 30%)
  // knowledgeDepth: 知识覆盖深度 (权重 30%)
  // reasoningPattern: 思维模式一致性 (权重 25%)
  // safetyCompliance: 安全合规性 (权重 15%)
  scoreBreakdown  Json    @default("{}")  // ScoreBreakdown object
  scoreFindings   Json    @default("[]")  // ScoreFinding[] array

  // Source corpus summary
  corpusItemCount  Int    @default(0)
  corpusTotalWords Int    @default(0)
  corpusSources    Json   @default("[]")  // string[] of source names

  // Versioning
  distillVersion   String  @default("0.1.0")
  distillDate      DateTime @default(now())

  // Status
  isActive        Boolean @default(true)
  isPublished     Boolean @default(false)  // published to website library

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([nameZh])
  @@index([domain])
  @@index([finalScore])
  @@index([isPublished])
  @@map("distilled_personas")
}

// ─── Device & Conversation Sync ─────────────────────────────────────────────────
// 支持同一账号多设备登录、对话记录本地存储与跨设备同步

model Device {
  // 直接用浏览器传入的 deviceFingerprint 作为主键（不再生成 cuid）
  // 这样 upsert 时 `where: { id: deviceId }` 直接命中，无需双 key
  id                  String   @id
  userId              String
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 设备信息
  deviceName   String?
  deviceType   DeviceType @default(DESKTOP)
  platform     String?
  browser      String?
  osVersion     String?

  // 同步状态
  lastSyncedAt DateTime @default(now())
  syncToken    String?

  // 活跃状态
  lastActiveAt DateTime @default(now())
  isActive    Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 关联: 每个设备有本地对话快照记录
  localConversations LocalConversation[]

  @@index([userId, lastActiveAt])
  @@map("devices")
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

// 本地对话快照: 记录每个设备上的本地对话元信息，用于同步时做 merge
// 不存具体消息内容（消息内容很大，存在本地 localStorage 里）
// 每次设备登录时，对比快照找出哪些对话需要 merge

model LocalConversation {
  id           String   @id @default(cuid())
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // 对话标识: 用 persona IDs 组合作为本地对话的全局唯一 ID
  // 这样跨设备时，同一组 persona 的对话可以 merge
  conversationKey String   // e.g. "wittgenstein-confucius" (排序后的 persona IDs join)
  personaIds    String[]            // 对应的 persona IDs（排序后）

  // 该设备上的本地状态
  localTitle   String?             // 本地设置的对话标题
  localTags    String[] @default([])

  // 消息计数（用于快速比对）
  localMessageCount Int    @default(0)

  // 消息哈希（用于快速检测变更）
  contentHash String?               // 消息内容的 SHA-256 哈希
  lastLocalUpdateAt DateTime @default(now())  // 本地最后更新时间

  // 对应数据库中的真实 conversation ID（如果已同步过）
  syncedConversationId String?       // 指向 conversations.id（如果有的话）

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([deviceId, conversationKey])
  @@index([deviceId])
  @@index([conversationKey])
  @@index([syncedConversationId])
  @@map("local_conversations")
}

// 同步操作日志: 记录每次同步的详情，用于冲突解决和审计
model SyncLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId     String?

  // 同步方向
  direction    SyncDirection  // PUSH_LOCAL | PULL_SERVER | MERGE

  // 同步的对话数量统计
  pushedCount  Int    @default(0)   // 上推的对话数
  pulledCount  Int    @default(0)   // 下拉的对话数
  mergedCount  Int    @default(0)   // 合并的对话数
  conflictCount Int   @default(0)   // 冲突数

  // 同步状态
  status      SyncStatus @default(SUCCESS)

  // 同步详情（JSON）
  details     Json?    @default("{}")
  // {
  //   "conversations": [
  //     { "key": "witt-conf", "action": "created", "conflict": false },
  //     { "key": "elon-musk", "action": "merged", "conflict": true, "resolution": "server_wins" }
  //   ]
  // }

  // 设备信息
  userAgent   String?
  ip          String?
  durationMs  Int?                // 同步耗时

  // 反向关系
  conflicts   SyncConflict[]

  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([deviceId])
  @@index([status])
  @@map("sync_logs")
}

enum SyncDirection {
  PUSH_LOCAL    // 本地 → 服务器
  PULL_SERVER   // 服务器 → 本地
  MERGE         // 双向合并
}

enum SyncStatus {
  SUCCESS
  PARTIAL     // 部分成功（有冲突）
  FAILED
  CONFLICT    // 完全冲突
}

enum ConflictType {
  CONTENT_OVERWRITE  // 双方都有消息，内容覆盖
  TITLE_CONFLICT    // 标题不同
  BOTH_CREATED      // 同一人格对话在两个设备同时创建
  DELETED_CONFLICT  // 一方删除，另一方有更新
}

enum ResolutionStrategy {
  SERVER_WINS      // 服务器版本优先
  LOCAL_WINS       // 本地版本优先
  MERGE_APPEND     // 合并追加（按时间排序）
  USER_DECIDES     // 需要用户手动选择
}

// 冲突记录: 存储每次同步中发生的具体冲突
model SyncConflict {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogId    String
  syncLog      SyncLog  @relation(fields: [syncLogId], references: [id], onDelete: Cascade)

  // 冲突的对话
  conversationKey String
  personaIds    String[]

  // 冲突数据
  localSnapshot Json?
  serverSnapshot Json?

  // 冲突类型
  conflictType  ConflictType
  // CONTENT_OVERWRITE: 双方都有消息，内容覆盖
  // TITLE_CONFLICT: 标题不同
  // BOTH_CREATED: 同一人格对话在两个设备同时创建
  // DELETED_CONFLICT: 一方删除，另一方有更新

  // 解决方式
  resolution    ResolutionStrategy?  // null = 未解决
  resolvedAt   DateTime?

  createdAt    DateTime @default(now())

  @@index([syncLogId])
  @@index([userId])
  @@map("sync_conflicts")
}

// 匿名/访客用户升级时的对话迁移记录
model ConversationMigration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 来源
  visitorId    String?             // 升级前的匿名 visitor ID
  sourceDeviceId String?           // 来源设备 ID

  // 迁移的对话
  conversationKey String
  personaIds    String[]

  // 迁移的数据
  messageCount  Int    @default(0)
  messagesJson  Json?  @default("[]")  // 迁移的消息内容（JSON 数组）

  status       String  @default("pending")  // pending | completed | failed
  error        String?

  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([userId])
  @@index([visitorId])
  @@map("conversation_migrations")
}

