# ============================================
# Hermes Agent — 环境变量配置
# 复制为 .env 后填入实际值
# ============================================

# ============================================
# 个人微信 (iLink Bot API)
# 通过 hermes gateway setup 扫码后自动填写
# ============================================
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=

# 私聊策略
WEIXIN_DM_POLICY=pairing
WEIXIN_ALLOWED_USERS=

# 群策略（默认关闭，需手动开启）
WEIXIN_GROUP_POLICY=allowlist
WEIXIN_GROUP_ALLOWED_USERS=

# ============================================
# 企业微信 (Wecom Callback)
# 在企业微信管理后台创建自建应用后获取
# ============================================
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_WEBHOOK_TOKEN=

# ============================================
# 通用配置
# ============================================
# 管理员私聊 ID（用于接收定时任务输出和告警）
WEIXIN_HOME_CHANNEL=admin_dm_id
WEIXIN_HOME_CHANNEL_NAME=Admin

# 默认 Persona（群未配置时使用）
DEFAULT_PERSONA=smart-assistant

# ============================================
# LLM 提供商
# ============================================
# DeepSeek（推荐，默认）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic（可选）
ANTHROPIC_API_KEY=

# 默认使用哪个提供商
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# ============================================
# MCP 服务器
# ============================================
# 数据库（SQLite，用于反馈收集）
# MCP_SQLITE_PATH=/Users/john/.hermes/data/assistant.db

# 文件系统（用于读写 Persona 配置）
# MCP_FILESYSTEM_ROOT=/Users/john/蒸馏2/wechat-assistant

# ============================================
# 管理后台
# ============================================
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
ADMIN_API_SECRET=change-me-in-production

# ============================================
# 定时任务
# ============================================
# Cron 表达式（使用 Hermes Background Session 执行）
# DAILY_DIGEST_CRON="0 9 * * 1-5"
# WEEKLY_REPORT_CRON="0 10 * * 1"
# INACTIVE_REMINDER_CRON="0 20 * * 5"
