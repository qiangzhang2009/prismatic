// ============================================
// Prisma Schema — WeChat Assistant (Hermes 集成版)
// 数据源：~/.hermes/data/wechat-assistant.db
// 运行 npx prisma db push 初始化
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // 指向 Hermes 的本地 SQLite 数据库
  // 在开发环境下使用 ~ 展开的绝对路径
  url      = env("DATABASE_URL")
}

// ----------------------------------------
// 群组配置
// ----------------------------------------
model Group {
  id        String   @id @default(cuid())
  name      String
  wechatId  String   @unique
  platform  String   @default("weixin")
  personaId String?
  persona   Persona? @relation(fields: [personaId], references: [id])
  policy    String   @default("allowlist")
  keywords  String   @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedback   Feedback[]
  messages   Message[]
  taskLogs   TaskLog[]
  violations Violation[]

  @@index([wechatId])
  @@index([platform])
}

// ----------------------------------------
// Persona 定义
// 内置：corpus/personas/JSON；自定义：数据库
// ----------------------------------------
model Persona {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  source    String   @default("local")
  config    String
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups Group[]

  @@index([slug])
}

// ----------------------------------------
// 消息记录
// ----------------------------------------
model Message {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  userName   String
  content    String
  type       String   @default("text")
  isFromBot  Boolean  @default(false)
  botPersona String?
  metadata   String?
  createdAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([createdAt])
  @@index([userId])
}

// ----------------------------------------
// 反馈记录
// ----------------------------------------
model Feedback {
  id         String    @id @default(cuid())
  groupId    String
  userId     String
  userName   String
  content    String
  sentiment  String?
  status     String    @default("new")
  tags       String    @default("[]")
  notes      String?
  reviewedBy String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  updatedAt  DateTime  @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([status])
  @@index([sentiment])
  @@index([createdAt])
}

// ----------------------------------------
// 违规记录
// ----------------------------------------
model Violation {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  userName  String
  type      String
  level     Int      @default(1)
  messageId String?
  content   String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
  @@index([type])
}

// ----------------------------------------
// 定时任务配置
// ----------------------------------------
model ScheduledTask {
  id        String    @id @default(cuid())
  name      String
  cron      String
  groups    String    @default("[]")
  personaId String
  template  String    @default("")
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  taskLogs TaskLog[]

  @@index([enabled])
  @@index([cron])
}

// ----------------------------------------
// 定时任务执行日志
// ----------------------------------------
model TaskLog {
  id          String    @id @default(cuid())
  taskId      String
  groupId     String?
  status      String
  output      String?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  task  ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  group Group?        @relation(fields: [groupId], references: [id])

  @@index([taskId])
  @@index([status])
  @@index([startedAt])
}

// ----------------------------------------
// 链接记录
// ----------------------------------------
model LinkRecord {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  userName    String
  url         String
  title       String?
  description String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([groupId])
  @@index([url])
}

// ----------------------------------------
// 活跃用户统计
// ----------------------------------------
model DailyStats {
  id            String   @id @default(cuid())
  groupId       String
  date          DateTime @default(now())
  messageCount  Int      @default(0)
  activeUsers   Int      @default(0)
  feedbackCount Int      @default(0)
  newUsers      Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([groupId, date])
  @@index([date])
}
